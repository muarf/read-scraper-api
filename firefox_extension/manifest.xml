{
  "manifest_version": 3,
  "name": "Mon Extension",
  "version": "1.0",
  "description": "Ouvre une fenêtre en arrière-plan et envoie l'URL à 127.0.0.1:5000",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "http://127.0.0.1:5000/"
  ],
  "icons": {
    "48": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.html"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["socket.io.js"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["images/icon16.png"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["images/icon48.png"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["images/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
